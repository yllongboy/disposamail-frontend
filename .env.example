# DisposaMail Frontend — production environment variables
#
# Copy this file to .env (gitignored) for local overrides, or set these
# variables in your CI/CD platform (GitHub Actions, Vercel, Netlify, etc.)
# before running `npm run build:prod`.
#
# All variables are optional.  If omitted, the values from environment.ts
# (the development defaults) are used instead.

# REST API base path served by your backend
# NG_API_URL=/api

# WebSocket endpoint of your backend
# NG_WS_URL=wss://api.yourdomain.com/ws

# Branding
# NG_APP_NAME=DisposaMail
# NG_APP_TAGLINE=Temporary Email, Zero Hassle
# NG_APP_URL=https://yourdomain.com

# Google Analytics 4 — leave unset or empty to disable
# NG_GA_TRACKING_ID=G-XXXXXXXXXX

# Google AdSense — leave unset or empty to disable ads
# NG_ADSENSE_PUBLISHER_ID=pub-0000000000000000
# NG_ADSENSE_SLOT_ID=0000000000

# localStorage key prefix
# NG_STORAGE_PREFIX=disposaMail_
