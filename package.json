{
  "name": "disposamail-frontend",
  "version": "1.0.0",
  "description": "Open-source disposable email frontend built with Angular 17. Generate temporary email addresses instantly with real-time email delivery.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/disposamail-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/disposamail-frontend/issues"
  },
  "homepage": "https://github.com/your-username/disposamail-frontend#readme",
  "keywords": [
    "disposable-email",
    "temporary-email",
    "angular",
    "email-client",
    "privacy",
